<idea-plugin>
  <id>com.aidimag.intellij</id>
  <name>aidimag</name>
  <vendor email="support@aidimag.dev" url="https://github.com">aidimag</vendor>
  <description>
    <![CDATA[
      aidimag dashboard and memory actions inside IntelliJ IDEA.
    ]]>
  </description>

  <depends>com.intellij.modules.platform</depends>
  <depends>org.jetbrains.plugins.terminal</depends>

  <extensions defaultExtensionNs="com.intellij">
    <notificationGroup id="aidimag" displayType="BALLOON" isLogByDefault="true"/>
    <!-- AidimagSettingsState and AidimagDashboardService are light services
         (@Service annotation) and must NOT also be registered here. -->
    <projectConfigurable instance="com.aidimag.intellij.settings.AidimagConfigurable" id="aidimag.settings" displayName="aidimag"/>
    <toolWindow id="aidimag" anchor="right" icon="/icons/aidimag_toolwindow.svg" factoryClass="com.aidimag.intellij.dashboard.AidimagToolWindowFactory" canCloseContents="false"/>
    <statusBarWidgetFactory id="AidimagMemoryStatus" implementation="com.aidimag.intellij.statusbar.MemoryStatusWidgetFactory"/>
    <statusBarWidgetFactory id="AidimagSyncStatus" implementation="com.aidimag.intellij.statusbar.SyncStatusWidgetFactory"/>
    <postStartupActivity implementation="com.aidimag.intellij.startup.AidimagStartupActivity"/>
  </extensions>

  <applicationListeners>
    <listener class="com.aidimag.intellij.startup.AidimagFocusListener"
              topic="com.intellij.openapi.application.ApplicationActivationListener"/>
  </applicationListeners>

  <actions>
    <group id="Aidimag.Group" text="aidimag" popup="true">
      <add-to-group group-id="ToolsMenu" anchor="last"/>
      <action id="Aidimag.OpenDashboard" class="com.aidimag.intellij.actions.OpenDashboardAction" text="Open Dashboard"/>
      <action id="Aidimag.Verify" class="com.aidimag.intellij.actions.VerifyMemoriesAction" text="Verify Memories"/>
      <action id="Aidimag.Sync" class="com.aidimag.intellij.actions.SyncTeamMemoryAction" text="Sync Team Memory"/>
      <action id="Aidimag.SyncKnowledge" class="com.aidimag.intellij.actions.SyncKnowledgeAction" text="Sync Knowledge Inbox"
              description="Summarize docs dropped in the knowledge inbox into reviewable, pinned-on-approve memory proposals"/>
      <action id="Aidimag.PinMemory" class="com.aidimag.intellij.actions.PinMemoryAction" text="Pin/Unpin Memory"
              description="Pinned memories never decay with age (evidence failure can still mark them stale)"/>
      <separator/>
      <action id="Aidimag.Login" class="com.aidimag.intellij.actions.LoginAction" text="Login (approve this device)"/>
      <action id="Aidimag.ConnectTickets" class="com.aidimag.intellij.actions.ConnectTicketsAction" text="Connect Ticketing App"/>
      <action id="Aidimag.ShowTicket" class="com.aidimag.intellij.actions.ShowTicketAction" text="Show Ticket"/>
      <action id="Aidimag.TicketBranch" class="com.aidimag.intellij.actions.TicketBranchAction" text="Create Ticket Branch"/>
    </group>
  </actions>
</idea-plugin>

