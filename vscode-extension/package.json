{
  "name": "aidimag-vscode",
  "displayName": "aidimag — repo brain",
  "description": "Persistent, verified memory for AI coding agents. Memory Explorer panel, detail view, and stale-memory warnings inside VSCode.",
  "version": "1.0.0",
  "publisher": "aidimag",
  "author": "Anup Khanal",
  "license": "MIT",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["AI", "Other"],
  "activationEvents": ["workspaceContains:.aidimag/**"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      { "command": "aidimag.openDashboard",          "title": "aidimag: Open Dashboard" },
      { "command": "aidimag.verify",                  "title": "aidimag: Verify Memories" },
      { "command": "aidimag.sync",                    "title": "aidimag: Sync Team Memory" },
      { "command": "aidimag.login",                   "title": "aidimag: Login (approve this device)" },
      { "command": "aidimag.pinMemory",               "title": "aidimag: Pin/Unpin Memory (quick-pick)" },
      { "command": "aidimag.connectTickets",          "title": "aidimag: Connect Ticketing App (Jira, GitHub, Linear…)" },
      { "command": "aidimag.showTicket",              "title": "aidimag: Show Ticket" },
      { "command": "aidimag.ticketBranch",            "title": "aidimag: Create Ticket Branch" },
      { "command": "aidimag.addMemory",               "title": "aidimag: Add Memory",           "icon": "$(add)"     },
      { "command": "aidimag.refreshMemoryExplorer",   "title": "aidimag: Refresh Memory Explorer", "icon": "$(refresh)" },
      { "command": "aidimag.openMemoryDetail",        "title": "aidimag: Open Memory Detail" },
      { "command": "aidimag.pinMemoryItem",           "title": "📌 Pin Memory" },
      { "command": "aidimag.unpinMemoryItem",         "title": "📌 Unpin Memory" },
      { "command": "aidimag.refuteMemoryItem",        "title": "✗ Refute Memory" },
      { "command": "aidimag.knowledgeSync",           "title": "aidimag: Sync Knowledge Inbox" },
      { "command": "aidimag.revealMemoryExplorer",    "title": "aidimag: Open Memory Explorer" },
      { "command": "aidimag.bootstrap",               "title": "aidimag: Bootstrap Starter Memory (survey repo)" },
      { "command": "aidimag.mine",                    "title": "aidimag: Mine Git History for Memories" },
      { "command": "aidimag.harvest",                 "title": "aidimag: Harvest AI Chat Transcripts" },
      { "command": "aidimag.brief",                   "title": "aidimag: Session Briefing" },
      { "command": "aidimag.gaps",                    "title": "aidimag: Show Knowledge Gaps" },
      { "command": "aidimag.verifyTrust",             "title": "aidimag: Review Synced-in Evidence (trust gate)" },
      { "command": "aidimag.generateContext",         "title": "aidimag: Generate Context Files (CLAUDE.md, .cursorrules…)" }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aidimag",
          "title": "aidimag",
          "icon": "media/brain.svg"
        }
      ]
    },
    "views": {
      "aidimag": [
        {
          "id": "aidimag.memoryExplorer",
          "name": "🧠 Memories"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "aidimag.refreshMemoryExplorer",
          "when": "view == aidimag.memoryExplorer",
          "group": "navigation@1"
        },
        {
          "command": "aidimag.addMemory",
          "when": "view == aidimag.memoryExplorer",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "aidimag.openMemoryDetail",
          "when": "viewItem =~ /aidimag\\.memory/",
          "group": "aidimag@1"
        },
        {
          "command": "aidimag.pinMemoryItem",
          "when": "viewItem == aidimag.memory.unpinned",
          "group": "aidimag@2"
        },
        {
          "command": "aidimag.unpinMemoryItem",
          "when": "viewItem == aidimag.memory.pinned",
          "group": "aidimag@2"
        },
        {
          "command": "aidimag.refuteMemoryItem",
          "when": "viewItem =~ /aidimag\\.memory/",
          "group": "aidimag@3"
        }
      ]
    },
    "configuration": {
      "title": "aidimag",
      "properties": {
        "aidimag.dimPath": {
          "type": "string",
          "default": "dim",
          "description": "Path to the dim CLI binary"
        },
        "aidimag.uiPort": {
          "type": "number",
          "default": 4517,
          "description": "Port for the dashboard server"
        },
        "aidimag.autoSyncMinutes": {
          "type": "number",
          "default": 10,
          "description": "Auto-sync team memory every N minutes (0 to disable)"
        },
        "aidimag.knowledgeWatch": {
          "type": "boolean",
          "default": true,
          "description": "Watch the knowledge inbox and auto-summarize dropped docs into review proposals (runs `dim knowledge sync`)"
        }
      }
    },
    "colors": [
      {
        "id": "aidimag.status.verified",
        "description": "Memory Explorer — VERIFIED memory color",
        "defaults": { "light": "#228B22", "dark": "#62C662", "highContrast": "#62C662" }
      },
      {
        "id": "aidimag.status.stale",
        "description": "Memory Explorer — STALE memory color",
        "defaults": { "light": "#BE5A00", "dark": "#F08C3C", "highContrast": "#F08C3C" }
      },
      {
        "id": "aidimag.status.unverified",
        "description": "Memory Explorer — UNVERIFIED memory color",
        "defaults": { "light": "#808080", "dark": "#808080", "highContrast": "#A0A0A0" }
      },
      {
        "id": "aidimag.status.refuted",
        "description": "Memory Explorer — REFUTED memory color",
        "defaults": { "light": "#A00000", "dark": "#DC5050", "highContrast": "#DC5050" }
      },
      {
        "id": "aidimag.kind.decision",
        "description": "Memory Explorer — DECISION kind color",
        "defaults": { "light": "#0050B4", "dark": "#5096FF", "highContrast": "#5096FF" }
      },
      {
        "id": "aidimag.kind.convention",
        "description": "Memory Explorer — CONVENTION kind color",
        "defaults": { "light": "#007864", "dark": "#32BEA0", "highContrast": "#32BEA0" }
      },
      {
        "id": "aidimag.kind.gotcha",
        "description": "Memory Explorer — GOTCHA kind color",
        "defaults": { "light": "#AA5000", "dark": "#E69632", "highContrast": "#E69632" }
      },
      {
        "id": "aidimag.kind.failedApproach",
        "description": "Memory Explorer — FAILED_APPROACH kind color",
        "defaults": { "light": "#A00000", "dark": "#DC5050", "highContrast": "#DC5050" }
      },
      {
        "id": "aidimag.kind.invariant",
        "description": "Memory Explorer — INVARIANT kind color",
        "defaults": { "light": "#6400A0", "dark": "#B464F0", "highContrast": "#B464F0" }
      },
      {
        "id": "aidimag.kind.architecture",
        "description": "Memory Explorer — ARCHITECTURE kind color",
        "defaults": { "light": "#003C8C", "dark": "#3C78DC", "highContrast": "#3C78DC" }
      },
      {
        "id": "aidimag.kind.todoContext",
        "description": "Memory Explorer — TODO_CONTEXT kind color",
        "defaults": { "light": "#505050", "dark": "#A0A0A0", "highContrast": "#A0A0A0" }
      },
      {
        "id": "aidimag.kind.guardrail",
        "description": "Memory Explorer — GUARDRAIL kind color",
        "defaults": { "light": "#C81E1E", "dark": "#F05A5A", "highContrast": "#F05A5A" }
      },
      {
        "id": "aidimag.kind.skill",
        "description": "Memory Explorer — SKILL kind color",
        "defaults": { "light": "#006EB4", "dark": "#3CAAE6", "highContrast": "#3CAAE6" }
      }
    ]
  },
  "scripts": {
    "package": "vsce package"
  }
}

